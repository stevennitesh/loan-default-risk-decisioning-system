# OS, editor, and notebook noise
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.ipynb_checkpoints/

# Local environment, secrets, and machine-specific config
.env
.env.*
!.env.example
*.local
.python-version

# Python environments, bytecode, build outputs, and package metadata
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
build/
dist/
*.egg-info/
.eggs/

# Python test, lint, type-check, and coverage caches
.pytest_cache/
pytest-cache-files-*/
.ruff_cache/
.mypy_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
coverage.xml
junit.xml
htmlcov/

# Local scratch and agent/tooling state
.tmp/*
!.tmp/.gitkeep
.agents/
.codex/

# Data: keep directory placeholders, not Kaggle/source/intermediate files
data/raw/*
data/parquet/*
data/db/*
data/external/*
data/interim/*
data/processed/*
data/features/*
!data/**/.gitkeep

# Local databases and query scratch files
*.duckdb
*.duckdb.wal
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Model and experiment artifacts
models/*
!models/.gitkeep
*.pkl
*.pickle
*.joblib
*.onnx
*.lgb
mlruns/
wandb/

# Generated reports, exports, and runtime artifacts
artifacts/
outputs/
reports/generated/
reports/v1/*
reports/post_v1/*
reports/ingestion_summary.csv
reports/feature_mart_profile.csv
reports/data_inventory.csv
reports/feature_inventory.csv
reports/model_run_summary.csv
reports/model_metrics_summary.csv
reports/model_comparison_summary.csv
reports/lightgbm_tuning_summary.csv
reports/split_summary.csv
reports/model_lift_by_decile.csv
reports/model_calibration_bins.csv
reports/model_confusion_matrix.csv
reports/model_threshold_metrics.csv
reports/validation_report.md
reports/business_value_analysis.md
reports/model_feature_importance.csv
reports/figures/roc_curve.png
reports/figures/pr_curve.png
reports/figures/calibration_curve.png
reports/figures/lift_chart.png
reports/figures/shap_summary.png
reports/dashboard_data/*
reports/dashboard_data_post_v1/*
reports/figures/generated/
reports/tables/generated/
!reports/**/.gitkeep

# Curated experiment evidence under reports/experiments/ is intentionally tracked.

# Power BI and Office temp files
*.pbix.Backup
*.pbit.Backup
~$*
powerbi/**/.pbi/
powerbi/**/PowerBICache/

# Logs and local profiling output
*.log
logs/
*.prof
